DATA_SOURCE_DIR=./data_source
PROCESSED_DIR=./data_source/processed
DOCUMENTS_PATH=./data_source/processed/documents.jsonl
TICKETS_PATH=./data_source/processed/tickets.jsonl
# Streamlit UI uses this when it runs outside Docker.
# The Docker UI service overrides it to http://api:8000 automatically.
INTERNAL_SUPPORT_API_BASE_URL=http://127.0.0.1:8000

COLLECTION_NAME=internal_support_copilot
INCLUDE_TICKETS=true

CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=8
FINAL_TOP_K=4

USE_CROSS_ENCODER=true
CROSS_ENCODER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
CROSS_ENCODER_TOP_K=5
CROSS_ENCODER_BATCH_SIZE=16

QDRANT_MODE=server
# Host-run bootstrap uses docker compose and expects Qdrant at http://localhost:6333.
# The Docker API service overrides this to http://qdrant:6333 automatically.
QDRANT_URL=http://localhost:6333
# Keep real API keys only in your local `.env`, not in source control.
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=internal_support_copilot_qdrant
QDRANT_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_PREFER_GRPC=true
USE_QDRANT_HYBRID=true

API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8501,http://127.0.0.1:8501
LOG_LEVEL=INFO
LOG_FORMAT=json
OBSERVABILITY_BACKEND=memory
OBSERVABILITY_TRACE_HISTORY_LIMIT=200
AUTH_ENABLED=true
AUTH_USER_HEADER=X-User-ID
AUTH_ROLE_HEADER=X-User-Role
AUTH_DEFAULT_ROLE=viewer
AUTH_ALLOW_ANONYMOUS_READS=true
AUTH_REQUIRE_USER_ID_FOR_OPERATOR=true

SESSION_HISTORY_MAX_MESSAGES=6
SESSION_STORE_BACKEND=redis
ACTION_STORE_BACKEND=redis
GRAPH_CHECKPOINTER_BACKEND=redis
# Host-run bootstrap expects Redis at localhost.
# The Docker API service overrides this to redis://redis:6379/0 automatically.
# If Redis uses credentials, keep the full URL only in your local `.env`.
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=internal_support_copilot
SESSION_STATE_TTL_SECONDS=0
ACTION_STATE_TTL_SECONDS=0
GRAPH_CHECKPOINT_TTL_SECONDS=0

LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# Set this to "none" for CPU-only setups or when bitsandbytes/CUDA is unavailable.
LLM_QUANTIZATION=4bit
LLM_MAX_NEW_TOKENS=640
LLM_MAX_INPUT_TOKENS=3072
LLM_DO_SAMPLE=false
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_REPETITION_PENALTY=1.08
# HF_HOME=./hf_cache


GITHUB_ACTIONS_ENABLED=false
GITHUB_API_BASE=https://api.github.com
GITHUB_API_VERSION=2026-03-10
GITHUB_HTTP_TIMEOUT=30

GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_INSTALLATION_ID=
# Point this to a local PEM file outside the repo when possible. Never commit the key file.
GITHUB_PRIVATE_KEY_PATH=
GITHUB_ALLOWED_ORGS=your-org
GITHUB_ALLOWED_REPOS=owner/repo1,owner/repo2
GITHUB_TEST_REPO=owner/repo1

GITHUB_REQUIRE_CONFIRM_FOR_WRITE=true
GITHUB_REQUIRE_CONFIRM_FOR_WORKFLOW=true

LOCAL_GIT_ACTIONS_ENABLED=false
LOCAL_GIT_DEFAULT_REPO_PATH=.
LOCAL_GIT_ALLOWED_ROOTS=.
LOCAL_GIT_REQUIRE_CONFIRM_FOR_WRITE=true
